if answer3 == "D":
    score += 1

print() #last space
print(f"You have completed the quiz! {userName}, your score total is {score} out of 3!")

#Leaderboard Section

file_name = "leaderboard.txt"

#Save the new score to the file
with open(file_name, "a") as file:
    file.write(f"{userName},{score}\n")

# Load all scores from the file
leaderboard = []

with open(file_name, "r") as file:
    for line in file:
        line = line.strip()
        if line == "":
            continue
        name_part, score_part = line.split(",")
        leaderboard.append((name_part, int(score_part)))

# Sort leaderboard by score (highest first)
leaderboard.sort(key=lambda entry: entry[1], reverse=True)

# Display leaderboard
print("Leaderboard (highest scores first):")
for name, score_value in leaderboard:
    print(f"{name}: {score_value}")
