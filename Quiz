print("D) Santiago")
answer2 = input("Your answer (A/B/C/D): ").upper()

if answer2 == "C":
    score += 1

print() #another space

#Question 3
print("Question 3: How many times have AC Milan won the European Cup/Champions League?")
print("A) 0")
print("B) 3")
print("C) 5")
