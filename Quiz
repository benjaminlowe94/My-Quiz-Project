'\n#welcome\n\nprint("Welcome to my quiz, Please enter your name")\nuserName = input("your name: ")\nscore = 0\nprint(f"Hi, {userName} You will be asked 3 questions, this quiz is multiple choice so you can select your answer")\nprint()\n\n#Question 1\nprint("Question 1: Which planet is closest to the sun?")\nprint("A) Venus")\nprint("B) Mercury")\nprint("C) Jupiter")\nprint("D) Saturn")\nanswer1 = input("Your answer (A/B/C/D): ").upper()\n\nif answer1 == "B":\n    score += 1\n\nprint() #space between questions\n\n#Question 2\nprint("Question 2: What is the capital of Peru?")\nprint("A) Madrid")\nprint("B) Berlin")\nprint("C) Lima")\nprint("D) Santiago")\nanswer2 = input("Your answer (A/B/C/D): ").upper()\n\nif answer2 == "C":\n    score += 1\n\nprint() #another space\n\n#Question 3\nprint("Question 3: How many times have AC Milan won the European Cup/Champions League?")\nprint("A) 0")\nprint("B) 3")\nprint("C) 5")\nprint("D) 7")\nanswer3 = input("Your answer (A/B/C/D): ").upper()\n\nif answer3 == "D":\n    score += 1\n\nprint() #last space\nprint(f"You have completed the quiz! {userName}, your score total is {score} out of 3!")\n\n#Leaderboard Section\n\nfile_name = "leaderboard.txt"\n\n# Save the new score to the file\nwith open(file_name, "a") as file:\n    file.write(f"{userName},{score}\n")\n\n# Load all scores from the file\nleaderboard = []\n\nwith open(file_name, "r") as file:\n    for line in file:\n        line = line.strip()\n        if line == "":\n            continue\n        name_part, score_part = line.split(",")\n        leaderboard.append((name_part, int(score_part)))\n\n# Sort leaderboard by score (highest first)\nleaderboard.sort(key=lambda entry: entry[1], reverse=True)\n\n# Display leaderboard\nprint("Leaderboard (highest scores first):")\nfor name, score_value in leaderboard:\n    print(f"{name}: {score_value}")\n'